# Supabase project used by functions for auth validation and privileged RPC/database calls.
# Keep these three values from the same Supabase project.
REMOTE_SUPABASE_URL=
REMOTE_SUPABASE_PUBLISHABLE_KEY=
REMOTE_SUPABASE_SECRET_KEY=

# Custom function-level service API key for routes that allow AuthMethod.SERVICE_API_KEY.
# This is not a Supabase client key.
REMOTE_SERVICE_API_KEY=

# User API key authentication cache.
UPSTASH_REDIS_URL=
UPSTASH_REDIS_TOKEN=

# OpenAI-backed structured output/chat helpers.
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4.1-mini
OPENAI_BASE_URL=

# SageMaker embedding endpoint used by hybrid search and embedding_ft.
SAGEMAKER_ENDPOINT_NAME=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=

# Cognito-backed account functions.
COGNITO_USER_POOL_ID=

# LangGraph-backed suggestion functions.
LANGGRAPH_API_URL=
LANGGRAPH_API_KEY=

# TIDAS package and national-carbon graph cache storage.
S3_BUCKET=
S3_PREFIX=
S3_ENDPOINT=
NATIONAL_CARBON_GRAPH_CACHE_BUCKET=
NATIONAL_CARBON_GRAPH_CACHE_PREFIX=
NATIONAL_CARBON_GRAPH_CACHE_SIGNED_URL_EXPIRES_IN=3600

# Worker-job cutover gates. Leave true unless deliberately testing fail-closed legacy paths.
WORKER_JOBS_CUTOVER_ENABLED=true

# embedding_ft database-update backoff.
EMBEDDING_FT_DB_LOCK_TIMEOUT=5s
EMBEDDING_FT_DB_STATEMENT_TIMEOUT=30s
EMBEDDING_FT_DB_RETRY_BACKOFF_SECONDS=300
