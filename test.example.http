### @name AI_Suggest：Remote
curl -i --location --request POST '{{$dotenv REMOTE_ENDPOINT}}/ai_suggest' \
    --header 'Content-Type: application/json' \
    --header 'Authorization: Bearer {{$dotenv USER_API_KEY}}' \
    --data '{
  "tidasData": {
    "processDataSet": {
      "@xmlns:common": "http://lca.jrc.it/ILCD/Common",
      "@xmlns": "http://lca.jrc.it/ILCD/Process",
      "@xmlns:xsi": "http://www.w3.org/2001/XMLSchema-instance",
      "@version": "1.1",
      "processInformation": {
        "dataSetInformation": {
          "common:UUID": "ab051324-d573-4f92-bedd-8bcb43f17cf3",
          "name": {
            "baseName": [
              { "@xml:lang": "en", "#text": "steel production" },
              { "@xml:lang": "zh", "#text": "钢铁生产" }
            ],
            "treatmentStandardsRoutes": [
              { "@xml:lang": "en", "#text": "none" }
            ],
            "mixAndLocationTypes": [
              { "@xml:lang": "en", "#text": "production mix" },
              { "@xml:lang": "zh", "#text": "生产混合" }
            ]
          },
          "common:generalComment": [
            {
              "@xml:lang": "en",
              "#text": "Basic steel process"
            }
          ],
          "classificationInformation": {
            "common:classification": {
              "common:class": [
                { "@level": "0", "@classId": "1", "#text": "Process" },
                { "@level": "1", "@classId": "1.1", "#text": "Steel" },
                { "@level": "2", "@classId": "1.1.1", "#text": "Production" },
                { "@level": "3", "@classId": "1.1.1.1", "#text": "BOF" }
              ]
            }
          }
        }
      }
    }
  },
  "dataType": "process",
  "options": {}
}'


============================================================
LCA Solve
============================================================
### @name LCA_Solve：Local
curl -i --location --request POST '{{$dotenv LOCAL_ENDPOINT}}/lca_solve' \
    --header 'Content-Type: application/json' \
    --header 'Authorization: Bearer {{$dotenv USER_JWT}}' \
    --header 'X-Idempotency-Key: local-debug-001' \
    --data '{
      "scope": "prod",
      "demand": {
        "process_index": 0,
        "amount": 1.0
      },
      "solve": {
        "return_x": true,
        "return_g": true,
        "return_h": true
      },
      "print_level": 0
    }'

### @name LCA_Solve：Local (USER_API_KEY)
curl -i --location --request POST '{{$dotenv LOCAL_ENDPOINT}}/lca_solve' \
    --header 'Content-Type: application/json' \
    --header 'Authorization: Bearer {{$dotenv USER_API_KEY}}' \
    --header 'X-Idempotency-Key: local-debug-api-key-001' \
    --data '{
      "scope": "prod",
      "demand": {
        "process_index": 0,
        "amount": 1.0
      },
      "solve": {
        "return_x": true,
        "return_g": true,
        "return_h": true
      },
      "print_level": 0
    }'

### @name LCA_Solve：Local (all_unit)
curl -i --location --request POST '{{$dotenv LOCAL_ENDPOINT}}/lca_solve' \
    --header 'Content-Type: application/json' \
    --header 'Authorization: Bearer {{$dotenv USER_JWT}}' \
    --header 'X-Idempotency-Key: local-debug-all-unit-001' \
    --data '{
      "scope": "prod",
      "demand_mode": "all_unit",
      "solve": {
        "return_x": false,
        "return_g": false,
        "return_h": true
      },
      "print_level": 0
    }'


### @name LCA_Job_Status：Local (path param)
curl -i --location --request GET '{{$dotenv LOCAL_ENDPOINT}}/lca_jobs/{{$dotenv LCA_JOB_ID}}' \
    --header 'Authorization: Bearer {{$dotenv USER_JWT}}'

### @name LCA_Job_Status：Local (query param)
curl -i --location --request GET '{{$dotenv LOCAL_ENDPOINT}}/lca_jobs?job_id={{$dotenv LCA_JOB_ID}}' \
    --header 'Authorization: Bearer {{$dotenv USER_JWT}}'

### @name LCA_Job_Status：Local (POST body, for supabase.functions.invoke)
curl -i --location --request POST '{{$dotenv LOCAL_ENDPOINT}}/lca_jobs' \
    --header 'Content-Type: application/json' \
    --header 'Authorization: Bearer {{$dotenv USER_JWT}}' \
    --data '{
      "job_id": "{{$dotenv LCA_JOB_ID}}"
    }'


### @name LCA_Result：Local (path param, metadata only)
curl -i --location --request GET '{{$dotenv LOCAL_ENDPOINT}}/lca_results/{{$dotenv LCA_RESULT_ID}}' \
    --header 'Authorization: Bearer {{$dotenv USER_JWT}}'

### @name LCA_Result：Local (query param)
curl -i --location --request GET '{{$dotenv LOCAL_ENDPOINT}}/lca_results?result_id={{$dotenv LCA_RESULT_ID}}' \
    --header 'Authorization: Bearer {{$dotenv USER_JWT}}'

### @name LCA_Result：Local (POST body, for supabase.functions.invoke)
curl -i --location --request POST '{{$dotenv LOCAL_ENDPOINT}}/lca_results' \
    --header 'Content-Type: application/json' \
    --header 'Authorization: Bearer {{$dotenv USER_JWT}}' \
    --data '{
      "result_id": "{{$dotenv LCA_RESULT_ID}}"
    }'


### @name LCA_Query_Results：Local (single process -> all impacts)
curl -i --location --request POST '{{$dotenv LOCAL_ENDPOINT}}/lca_query_results' \
    --header 'Content-Type: application/json' \
    --header 'Authorization: Bearer {{$dotenv USER_JWT}}' \
    --data '{
      "scope": "prod",
      "data_scope": "current_user",
      "mode": "process_all_impacts",
      "process_id": "{{$dotenv LCA_PROCESS_ID}}"
    }'

### @name LCA_Query_Results：Local (multi process -> one impact)
curl -i --location --request POST '{{$dotenv LOCAL_ENDPOINT}}/lca_query_results' \
    --header 'Content-Type: application/json' \
    --header 'Authorization: Bearer {{$dotenv USER_JWT}}' \
    --data '{
      "scope": "prod",
      "data_scope": "current_user",
      "mode": "processes_one_impact",
      "process_ids": ["{{$dotenv LCA_PROCESS_ID}}"],
      "impact_id": "{{$dotenv LCA_IMPACT_ID}}"
    }'

### @name LCA_Query_Results：Local (snapshot hotspot ranking -> one impact)
curl -i --location --request POST '{{$dotenv LOCAL_ENDPOINT}}/lca_query_results' \
    --header 'Content-Type: application/json' \
    --header 'Authorization: Bearer {{$dotenv USER_JWT}}' \
    --data '{
      "scope": "prod",
      "data_scope": "all_data",
      "mode": "processes_one_impact",
      "impact_id": "{{$dotenv LCA_IMPACT_ID}}",
      "top_n": 20,
      "sort_by": "absolute_value",
      "sort_direction": "desc"
    }'

### @name LCA_Contribution_Path：Local
curl -i --location --request POST '{{$dotenv LOCAL_ENDPOINT}}/lca_contribution_path' \
    --header 'Content-Type: application/json' \
    --header 'Authorization: Bearer {{$dotenv USER_JWT}}' \
    --header 'X-Idempotency-Key: local-debug-path-001' \
    --data '{
      "scope": "prod",
      "data_scope": "current_user",
      "process_id": "{{$dotenv LCA_PROCESS_ID}}",
      "impact_id": "{{$dotenv LCA_IMPACT_ID}}",
      "amount": 1.0,
      "options": {
        "max_depth": 4,
        "top_k_children": 5,
        "cutoff_share": 0.01,
        "max_nodes": 200
      }
    }'

### @name LCA_Contribution_Path_Result：Local (query param)
curl -i --location --request GET '{{$dotenv LOCAL_ENDPOINT}}/lca_contribution_path_result?result_id={{$dotenv LCA_RESULT_ID}}' \
    --header 'Authorization: Bearer {{$dotenv USER_JWT}}'

### @name LCA_Contribution_Path_Result：Local (POST)
curl -i --location --request POST '{{$dotenv LOCAL_ENDPOINT}}/lca_contribution_path_result' \
    --header 'Content-Type: application/json' \
    --header 'Authorization: Bearer {{$dotenv USER_JWT}}' \
    --data '{
      "result_id": "{{$dotenv LCA_RESULT_ID}}"
    }'
