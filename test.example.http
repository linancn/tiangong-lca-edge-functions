============================================================
Embed
============================================================
### @name Embed：Local
curl -i --location --request POST '{{$dotenv LOCAL_ENDPOINT}}/embed' \
    --header 'Content-Type: application/json' \
    --header 'x_key: {{$dotenv X_KEY}}' \
    --data '{"query":"二氧化碳排放"}'

### @name Embed：Remote
curl -i --location --request POST '{{$dotenv REMOTE_ENDPOINT}}/embed' \
    --header 'Content-Type: application/json' \
    --header 'x_key: {{$dotenv X_KEY}}' \
    --data '{"query": "二氧化碳排放"}'


